{
  "name": "koda",
  "version": "0.2.0",
  "private": true,
  "description": "Koda — Professor de programação com IA (Web + WhatsApp)",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@koda/web",
    "dev:whatsapp": "turbo dev --filter=@koda/whatsapp",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
