# ==============================================
# Koda — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite .env com credenciais reais

# --- Servidor ---
PORT=3333

# --- Supabase ---
# URL do projeto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://seu-projeto.supabase.co
# Chave service_role (Settings → API → service_role key) — NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic (Claude) ---
# API key da Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# --- Evolution API (WhatsApp) ---
# URL da instância Evolution na VPS
EVOLUTION_API_URL=https://evolution.seudominio.com
# API key da instância Evolution
EVOLUTION_API_KEY=sua-chave-evolution
# Nome da instância no Evolution
EVOLUTION_INSTANCE=koda

# --- AIOX (framework) ---
NODE_ENV=development
